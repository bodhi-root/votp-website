---
interface Props {
    id: string;
    title: string;
}

const { id, title } = Astro.props;
---

<article class="mantra" id={id}>
    <h2 class="mantra-title">{title}</h2>

    {Astro.slots.has('translation') && (
        <div class="mantra-section">
            <!--<h3>Translation</h3> -->
            <div class="mantra-translation">
                <slot name="translation" />
            </div>
        </div>
    )}

    <div class="mantra-section">
        <h3>Sanskrit</h3>
        <div class="mantra-sanskrit">
            <slot name="sanskrit" />
        </div>
    </div>

    <div class="mantra-section">
        <h3>Transliteration</h3>
        <div class="mantra-transliteration">
            <slot name="transliteration" />
        </div>
    </div>

    {Astro.slots.has('definitions') && (
        <div class="mantra-section">
            <h3>Definitions</h3>
            <div class="mantra-definitions">
                <slot name="definitions" />
            </div>
        </div>
    )}

    

    {Astro.slots.has('commentary') && (
        <div class="mantra-section">
            <h3>Commentary</h3>
            <div class="mantra-commentary">
                <slot name="commentary" />
            </div>
        </div>
    )}

    {Astro.slots.has('notes') && (
        <div class="mantra-section">
            <h3>Notes</h3>
            <div class="mantra-notes">
                <slot name="notes" />
            </div>
        </div>
    )}

    {Astro.slots.has('resources') && (
        <div class="mantra-section">
            <h3>Resources</h3>
            <div class="mantra-resources">
                <slot name="resources" />
            </div>
        </div>
    )}

    <div class="mantra-back-to-top">
        <a href="#top">↑ Back to top</a>
    </div>
</article>
