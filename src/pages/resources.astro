---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Resources - Visions on the Path">
    <section class="hero">
        <div class="hero-content">
            <h1>Resources</h1>
            <p>Curated guides, reading lists, and links to support your journey along the Kriya Yoga path.</p>
        </div>
    </section>

    <section class="content-grid">
        <div class="card">
            <h2>Essential Texts</h2>
            <p>The Yoga Sutras of Patanjali, Bhagavad Gita, and Autobiography of a Yogi - foundational readings for understanding Kriya Yoga.</p>
            <p class="card-meta">Recommended translations included</p>
        </div>

        <div class="card">
            <h2>Practice Guides</h2>
            <p>Step-by-step instructions for breath work, meditation postures, and establishing a daily practice routine.</p>
            <p class="card-meta">Beginner to advanced levels</p>
        </div>

        <div class="card">
            <h2>Audio & Video</h2>
            <p>Guided meditations, mantra chanting demonstrations, and talks on yogic philosophy and technique.</p>
            <p class="card-meta">Free and accessible</p>
        </div>

        <div class="card">
            <h2>Teachers & Lineage</h2>
            <p>Links to respected teachers and organizations preserving the authentic Kriya Yoga tradition.</p>
            <p class="card-meta">Vetted sources only</p>
        </div>
    </section>

    <section class="featured">
        <div class="featured-content">
            <h2>Recommended Books</h2>
            <div class="link-list">
                <div class="link-item">
                    <div class="link-icon">📖</div>
                    <div class="link-content">
                        <h3>The Yoga Sutras of Patanjali</h3>
                        <p>Translation by Sri Swami Satchidananda - Clear, accessible interpretation</p>
                    </div>
                </div>
                <div class="link-item">
                    <div class="link-icon">📖</div>
                    <div class="link-content">
                        <h3>Autobiography of a Yogi</h3>
                        <p>Paramahansa Yogananda - Classic introduction to Kriya Yoga</p>
                    </div>
                </div>
                <div class="link-item">
                    <div class="link-icon">📖</div>
                    <div class="link-content">
                        <h3>The Bhagavad Gita</h3>
                        <p>Translation by Eknath Easwaran - Practical wisdom for daily life</p>
                    </div>
                </div>
            </div>
        </div>
    </section>
</BaseLayout>
