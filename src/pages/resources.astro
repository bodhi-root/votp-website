---
import BaseLayout from '../layouts/BaseLayout.astro';
import LinkItem from '../components/LinkItem.astro';
---

<BaseLayout title="Resources - Visions on the Path">
    <section class="hero" id="top">
        <div class="hero-content">
            <h1>Resources</h1>
            <p>Useful books, websites, and other resources</p>
        </div>
    </section>

    <div class="mantras-container">

        <section class="mantra-toc-section">
            <!-- <h2>Table of Contents</h2> -->
            <nav class="mantra-toc">
                <ul>
                    <li><a href="#my-links">My Links</a></li>
                    <li><a href="#kriya-yoga-online">Kriya Yoga Online</a></li>
                    <li><a href="#yoga">Yoga</a></li>
                    <li><a href="#channeled-entities">Channeled Entities</a></li>
                    <li><a href="#sanskrit">Sanskrit</a></li>
                </ul>
            </nav>
        </section>

        <article class="mantra" id="my-links">
            <h2 class="mantra-title">My Links</h2>
            <div class="mantra-section">
                <div class="link-list">
                    <LinkItem
                        href="https://www.youtube.com/@VisionsOnThePath"
                        iconSrc="/images/youtube-icon.svg"
                        iconAlt="YouTube"
                        title="Videos: Visions on the Path"
                        description="YouTube channel with videos related to Kriya Yoga, meditation, and spirituality"
                    />
                    <LinkItem
                        href="https://visionsonthepathblog.substack.com"
                        iconSrc="/images/votp-substack-logo.png"
                        iconAlt="Visions on the Path Blog Logo"
                        title="Blog: Visions on the Path"
                        description="Writings about spirituality, my spiritual journey, and thoughts"
                    />
                    <LinkItem
                        href="https://memoriesofhome.substack.com/"
                        iconSrc="/images/memories-of-home-logo.webp"
                        iconAlt="Memories of Home Logo"
                        title="Blog: Memories of Home"
                        description="Blog posts intended to remind people of the the love and beauty in our heart and the world."
                    />
                    <LinkItem
                        href="https://mindfulai.substack.com/"
                        iconSrc="/images/mindful-ai-logo.png"
                        iconAlt="Mindful AI Logo"
                        title="Blog: Mindful AI"
                        description="Examples of using GenAI for spiritual pursuits and psychological wellbeing."
                    />
                </div>
            </div>
            <div class="mantra-back-to-top">
                <a href="#top">↑ Back to top</a>
            </div>
        </article>

        <article class="mantra" id="kriya-yoga-online">
            <h2 class="mantra-title">Kriya Yoga Online</h2>
            <div class="mantra-section">
                <div class="resource-list">
                    <!-- Add Kriya Yoga Online resources here -->
                </div>
            </div>
            <div class="mantra-back-to-top">
                <a href="#top">↑ Back to top</a>
            </div>
        </article>

        <article class="mantra" id="yoga">
            <h2 class="mantra-title">Yoga</h2>
            <div class="mantra-section">
                <div class="resource-list">
                    <!-- Add Yoga resources here -->
                </div>
            </div>
            <div class="mantra-back-to-top">
                <a href="#top">↑ Back to top</a>
            </div>
        </article>

        <article class="mantra" id="channeled-entities">
            <h2 class="mantra-title">Channeled Entities</h2>
            <div class="mantra-section">
                <div class="resource-list">
                    <!-- Add Channeled Entities resources here -->
                </div>
            </div>
            <div class="mantra-back-to-top">
                <a href="#top">↑ Back to top</a>
            </div>
        </article>

        <article class="mantra" id="sanskrit">
            <h2 class="mantra-title">Sanskrit</h2>
            <div class="mantra-section">
                <div class="resource-list">
                    <!-- Add Sanskrit resources here -->
                </div>
            </div>
            <div class="mantra-back-to-top">
                <a href="#top">↑ Back to top</a>
            </div>
        </article>

    </div>
</BaseLayout>
