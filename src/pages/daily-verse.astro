---
import BaseLayout from '../layouts/BaseLayout.astro';

// Mock data - will be replaced with actual logic later
const verse = {
    index: 1,
    pada: 1,
    sutra: 1,
    devanagari: "अथ योगानुशासनम्॥१॥",
    iast: "Atha yogānuśāsanam",
    english: "And now begins (atha) the instruction (anuśāsanam) regarding Yoga (yoga)||1||"
};
---

<BaseLayout title="Daily Verse - Visions on the Path">
    <section class="hero">
        <div class="hero-content">
            <h1>Daily Verse</h1>
            <p>Random sutra from the Yoga Sutras</p>
        </div>
    </section>

    <section class="verse-of-the-day">
        <div class="verse-container">
            <!-- Verse Display with Navigation -->
            <div class="verse-content-wrapper">
                <!-- Left Arrow -->
                <button class="arrow-btn prev-btn" aria-label="Previous verse">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M15 18l-6-6 6-6"/>
                    </svg>
                </button>

                <!-- Verse Content -->
                <div class="verse-content">
                    <p class="verse-date">January 1, 2026</p>
                    <h2 class="verse-title">Yoga Sutra {verse.pada}.{verse.sutra}</h2>

                    <p class="verse-devanagari">{verse.devanagari}</p>

                    <p class="verse-iast">{verse.iast}</p>

                    <p class="verse-english">{verse.english}</p>
                </div>

                <!-- Right Arrow -->
                <button class="arrow-btn next-btn" aria-label="Next verse">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M9 18l6-6-6-6"/>
                    </svg>
                </button>
            </div>

            <!-- Mode Toggle Tabs -->
            <div class="mode-toggle">
                <button class="mode-tab active" data-mode="sequential">Sequential</button>
                <button class="mode-tab" data-mode="random">Random</button>
            </div>

            <!-- Mode Description -->
            <p class="mode-description" data-mode="sequential">
                Arrows navigate to next and previous verses.
            </p>
            <p class="mode-description hidden" data-mode="random">
                Arrows navigate to random verses based on the date.
            </p>
        </div>
    </section>
</BaseLayout>

<style>
    .verse-of-the-day {
        background: white;
        padding: 2rem 2rem 4rem;
        min-height: 60vh;
    }

    .verse-container {
        max-width: 900px;
        margin: 0 auto;
    }

    /* Verse Content Wrapper with Arrow Navigation */
    .verse-content-wrapper {
        display: flex;
        align-items: center;
        gap: 1.5rem;
        margin-bottom: 2rem;
    }

    .arrow-btn {
        flex-shrink: 0;
        width: 48px;
        height: 48px;
        display: flex;
        align-items: center;
        justify-content: center;
        background: white;
        border: 2px solid #CBD5E0;
        border-radius: 50%;
        cursor: pointer;
        transition: all 0.2s ease;
        color: #4A5568;
    }

    .arrow-btn:hover {
        background: #F7FAFC;
        border-color: #4A5568;
        color: #2D3748;
    }

    .arrow-btn:active {
        transform: scale(0.95);
    }

    .arrow-btn svg {
        width: 24px;
        height: 24px;
    }

    /* Verse Content */
    .verse-content {
        flex: 1;
        text-align: center;
        padding: 3rem 2rem;
        border-radius: 12px;
        background: #FAFAFA;
    }

    .verse-date {
        font-size: 0.875rem;
        color: #718096;
        font-weight: 500;
        margin-bottom: 0.5rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }

    .verse-title {
        color: #2D3748;
        font-size: 1.5rem;
        margin-bottom: 2rem;
        font-weight: 600;
    }

    .verse-devanagari {
        font-size: 2rem;
        margin-bottom: 1.5rem;
        color: #1A202C;
        line-height: 1.6;
    }

    .verse-iast {
        font-size: 1.5rem;
        font-style: italic;
        color: #4A5568;
        margin-bottom: 1.5rem;
    }

    .verse-english {
        font-size: 1.125rem;
        color: #2D3748;
        line-height: 1.8;
        max-width: 600px;
        margin: 0 auto;
    }

    /* Mode Toggle Tabs */
    .mode-toggle {
        display: flex;
        gap: 0;
        justify-content: center;
        border-bottom: 2px solid #E2E8F0;
        max-width: 400px;
        margin: 0 auto;
    }

    .mode-tab {
        padding: 0.75rem 2rem;
        background: transparent;
        border: none;
        border-bottom: 3px solid transparent;
        color: #718096;
        font-size: 0.95rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s ease;
        position: relative;
        top: 2px;
    }

    .mode-tab:hover {
        color: #4A5568;
        background: #F7FAFC;
    }

    .mode-tab.active {
        color: #2D3748;
        border-bottom-color: #4A5568;
    }

    /* Mode Description */
    .mode-description {
        text-align: center;
        color: #718096;
        font-size: 0.9rem;
        margin-top: 1rem;
        line-height: 1.6;
        max-width: 400px;
        margin-left: auto;
        margin-right: auto;
    }

    .mode-description.hidden {
        display: none;
    }

    /* Responsive Design */
    @media (max-width: 768px) {
        .verse-of-the-day {
            padding: 2rem 1rem;
        }

        .verse-content-wrapper {
            gap: 0.5rem;
        }

        .arrow-btn {
            width: 40px;
            height: 40px;
        }

        .arrow-btn svg {
            width: 20px;
            height: 20px;
        }

        .verse-content {
            padding: 2rem 1rem;
        }

        .verse-devanagari {
            font-size: 1.5rem;
        }

        .verse-iast {
            font-size: 1.25rem;
        }

        .verse-english {
            font-size: 1rem;
        }

        .mode-toggle {
            max-width: 100%;
        }

        .mode-tab {
            flex: 1;
            padding: 0.75rem 1rem;
            font-size: 0.875rem;
        }
    }
</style>

<script>
    // Mode toggle functionality (placeholder)
    document.addEventListener('DOMContentLoaded', () => {
        const modeTabs = document.querySelectorAll<HTMLButtonElement>('.mode-tab');
        const modeDescriptions = document.querySelectorAll<HTMLParagraphElement>('.mode-description');

        modeTabs.forEach(tab => {
            tab.addEventListener('click', () => {
                modeTabs.forEach(t => t.classList.remove('active'));
                tab.classList.add('active');

                const mode = tab.dataset.mode;

                // Show/hide appropriate description
                modeDescriptions.forEach(desc => {
                    if (desc.dataset.mode === mode) {
                        desc.classList.remove('hidden');
                    } else {
                        desc.classList.add('hidden');
                    }
                });

                console.log(`Mode switched to: ${mode}`);
                // Logic will be implemented later
            });
        });

        // Navigation functionality (placeholder)
        const prevBtn = document.querySelector<HTMLButtonElement>('.prev-btn');
        const nextBtn = document.querySelector<HTMLButtonElement>('.next-btn');

        prevBtn?.addEventListener('click', () => {
            console.log('Previous verse clicked');
            // Logic will be implemented later
        });

        nextBtn?.addEventListener('click', () => {
            console.log('Next verse clicked');
            // Logic will be implemented later
        });
    });
</script>
