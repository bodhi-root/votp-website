---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Daily Quotes - Visions on the Path">
    <section class="hero">
        <div class="hero-content">
            <h1>Daily Quotes</h1>
            <p>Contemplative wisdom from the Yoga Sutras and Bhagavad Gita to carry with you throughout your day.</p>
        </div>
    </section>

    <section class="featured">
        <div class="featured-content">
            <h2>Today's Reflection</h2>
            <div class="card">
                <h2>Yoga Sutra 1.2</h2>
                <p style="font-size: 1.1rem; font-style: italic; margin-bottom: 1.5rem;">
                    "Yogaś citta-vṛtti-nirodhaḥ"
                </p>
                <p>
                    Yoga is the settling of the mind into silence. When the fluctuations of thought cease,
                    we rest in our true nature—clear, spacious, and aware.
                </p>
                <p class="card-meta">Practice: Notice when thoughts arise. Without judgment, return to breath.</p>
            </div>
        </div>
    </section>

    <section class="content-grid">
        <div class="card">
            <h2>Weekly Archive</h2>
            <p>Access previous daily quotes and reflections from the past week.</p>
            <p class="card-meta">Coming soon</p>
        </div>

        <div class="card">
            <h2>Subscribe</h2>
            <p>Receive daily wisdom directly to your inbox each morning.</p>
            <p class="card-meta">Email notifications available</p>
        </div>
    </section>
</BaseLayout>
