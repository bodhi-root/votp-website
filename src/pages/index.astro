---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
---

<BaseLayout title="Home - Visions on the Path">
    <section class="hero">
        <div class="hero-content">
            <h1>Kriya Yoga for a Quiet Mind</h1>
            <p>A modern, uncluttered space to explore breath, mantra, and meditation. Move gently, notice deeply, and walk the path with steadiness and clarity.</p>
        </div>
        <div class="hero-visual">
            <svg width="280" height="280" viewBox="0 0 280 280" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <linearGradient id="ensoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" style="stop-color:#5d7a99;stop-opacity:0.3" />
                        <stop offset="100%" style="stop-color:#3498db;stop-opacity:0.6" />
                    </linearGradient>
                </defs>
                <circle cx="140" cy="140" r="120" fill="none" stroke="url(#ensoGrad)" stroke-width="3" opacity="0.5"/>
                <circle cx="140" cy="140" r="90" fill="none" stroke="url(#ensoGrad)" stroke-width="2" opacity="0.4"/>
                <circle cx="140" cy="140" r="60" fill="none" stroke="url(#ensoGrad)" stroke-width="1.5" opacity="0.3"/>
                <path d="M 140 20 A 120 120 0 0 1 260 140" fill="none" stroke="#3498db" stroke-width="6" stroke-linecap="round" opacity="0.7"/>
            </svg>
        </div>
    </section>

    <section class="content-grid">
        <Card
            title="Mantras"
            description="Short, potent phrases to center awareness. Begin with breath, repeat softly, and let the resonance settle."
            meta='Start with "So-Ham" and "Om Shanti."'
            href="/mantras"
        />

        <Card
            title="Daily Quotes"
            description="A verse a day from the Yoga Sutras and Bhagavad Gita—contemplative wisdom to carry with you."
            meta="New quote each day."
            href="/daily-quotes"
        />

        <Card
            title="Resources"
            description="Guides, reading lists, and links to my content and other teachers supporting the Kriya Yoga path."
            meta="Books, articles & audio available."
            href="/resources"
        />

        <Card
            title="About"
            description="Our intention is simplicity: remove what's not needed, support what is, and invite quiet transformation."
            meta="Based in practice, informed by lineage."
            href="/about"
        />
    </section>

    <section class="featured">
        <div class="featured-content">
            <h2>My Content & Links</h2>
            <div class="link-list">
                <a href="https://www.youtube.com/@VisionsOnThePath" class="link-item">
                    <div class="link-icon">
                        <img src="/youtube-icon.svg" alt="YouTube" />
                    </div>
                    <div class="link-content">
                        <h3>Videos: Visions on the Path</h3>
                        <p>A collection of videos related to Kriya Yoga, meditation, and spirituality</p>
                    </div>
                </a>
                <a href="https://visionsonthepathblog.substack.com" class="link-item">
                    <div class="link-icon">✍</div>
                    <div class="link-content">
                        <h3>Blog: Visions on the Path</h3>
                        <p>Writings and essays on spirituality and my spiritual journey and thoughts</p>
                    </div>
                </a>
                <a href="https://memoriesofhome.substack.com/" class="link-item">
                    <div class="link-icon">✍</div>
                    <div class="link-content">
                        <h3>Blog: Memories of Home</h3>
                        <p>Blog posts intended to remind people of the the love and beauty in our heart and the world.</p>
                    </div>
                </a>
                <a href="https://mindfulai.substack.com/" class="link-item">
                    <div class="link-icon">✍</div>
                    <div class="link-content">
                        <h3>Blog: Mindful AI</h3>
                        <p>Examples of using GenAI for spiritual pursuits and psychological wellbeing.</p>
                    </div>
                </a>
                <!--
                <a href="https://www.tiktok.com/@visionsonthepath" class="link-item">
                    <div class="link-icon">🎵</div>
                    <div class="link-content">
                        <h3>TikTok</h3>
                        <p>Short-form spiritual content and reflections</p>
                    </div>
                </a>
                 -->
            </div>
        </div>
    </section>
</BaseLayout>
