---
import BaseLayout from '../layouts/BaseLayout.astro';
import Card from '../components/Card.astro';
import LinkItem from '../components/LinkItem.astro';
---

<BaseLayout title="Home - Visions on the Path">
    <section class="hero">
        <div class="hero-content">
            <h1>Home Page of a Kriya Yoga Student</h1>
            <p>Collection of spiritual content and links.</p>
            <p>Peace, Love, and Best Wishes to all.</p>
            <p>Namaste.</p>
        </div>
        <div class="hero-visual">
            <img src="/images/lotus-flower-homepage.png" alt="Enso Circle" width="280" height="280" />
            <!-- <svg width="280" height="280" viewBox="0 0 280 280" xmlns="http://www.w3.org/2000/svg">
                <defs>
                    <linearGradient id="ensoGrad" x1="0%" y1="0%" x2="100%" y2="100%">
                        <stop offset="0%" style="stop-color:#5d7a99;stop-opacity:0.3" />
                        <stop offset="100%" style="stop-color:#3498db;stop-opacity:0.6" />
                    </linearGradient>
                </defs>
                <circle cx="140" cy="140" r="120" fill="none" stroke="url(#ensoGrad)" stroke-width="3" opacity="0.5"/>
                <circle cx="140" cy="140" r="90" fill="none" stroke="url(#ensoGrad)" stroke-width="2" opacity="0.4"/>
                <circle cx="140" cy="140" r="60" fill="none" stroke="url(#ensoGrad)" stroke-width="1.5" opacity="0.3"/>
                <path d="M 140 20 A 120 120 0 0 1 260 140" fill="none" stroke="#3498db" stroke-width="6" stroke-linecap="round" opacity="0.7"/>
            </svg> -->
        </div>
    </section>
    
    <section class="content-grid">
        <Card
            title="Mantras"
            description="Collection of mantras in Sanskrit with translations, definitions, notes, and links to more resources."
            href="/mantras"
        />

        <Card
            title="Daily Verse"
            description="A verse each day from the Yoga Sutras."
            href="/daily-quotes"
        />

        <Card
            title="Resources"
            description="Curated list of books, websites, and other useful resources."
            href="/resources"
        />

        <Card
            title="About Me"
            description="A bit of info about me (in case you're curious)."
            href="/about"
        />
    </section>

    <section class="featured">
        <div class="featured-content">
            <h2>Links to My Content</h2>
            <div class="link-list">
                <LinkItem
                    href="https://www.youtube.com/@VisionsOnThePath"
                    iconSrc="/images/youtube-icon.svg"
                    iconAlt="YouTube"
                    title="Videos: Visions on the Path"
                    description="YouTube channel with videos related to Kriya Yoga, meditation, and spirituality"
                />
                <LinkItem
                    href="https://visionsonthepathblog.substack.com"
                    iconSrc="/images/votp-substack-logo.png"
                    iconAlt="Visions on the Path Blog Logo"
                    title="Blog: Visions on the Path"
                    description="Writings about spirituality, my spiritual journey, and thoughts"
                />
                <LinkItem
                    href="https://memoriesofhome.substack.com/"
                    iconSrc="/images/memories-of-home-logo.webp"
                    iconAlt="Memories of Home Logo"
                    title="Blog: Memories of Home"
                    description="Blog posts intended to remind people of the the love and beauty in our heart and the world."
                />
                <LinkItem
                    href="https://mindfulai.substack.com/"
                    iconSrc="/images/mindful-ai-logo.png"
                    iconAlt="Mindful AI Logo"
                    title="Blog: Mindful AI"
                    description="Examples of using GenAI for spiritual pursuits and psychological wellbeing."
                />
            </div>
        </div>
    </section>
</BaseLayout>
